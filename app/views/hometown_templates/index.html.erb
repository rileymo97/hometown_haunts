<h1>
  List of all hometowns
</h1>

<hr>

<article>
  <header>
    <h2>
      Add a new hometown
    </h2>
  </header>

  <form action="/insert_hometown" method="post">
    <div>
      <label for="name_box">
        Name
      </label>

      <input type="text" id="name_box" name="query_name">
    </div>

    <button type="submit">
      Create hometown
    </button>
  </form>
</article>

<hr>

<article>
  <ul>
    <% @list_of_hometowns.each do |a_hometown| %>
      <li>
        <a href="/hometowns/<%= a_hometown.id %>">
          Hometown #<%= a_hometown.id %>
        </a>
      </li>
    <% end %>
  </ul>
</article>

<hr>
